{
  "name": "heima-jizhang",
  "private": true,
  "version": "1.0.0",
  "description": "黑马记账 - 个人收支记账软件",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "node scripts/dev.cjs",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "vite build && electron ."
  },
  "dependencies": {
    "echarts": "^5.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-echarts": "^7.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^33.4.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.heima.jizhang",
    "productName": "黑马记账",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "黑马记账",
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052"
    }
  }
}
